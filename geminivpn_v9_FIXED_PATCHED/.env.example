# GeminiVPN — Example Environment (copy to .env and fill in your values)

# ── Database (SQLite — file in ./database/geminivpn.db) ───────────────────────
DATABASE_URL=file:/app/database/geminivpn.db

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=https://yourdomain.example.com
SERVER_PUBLIC_IP=YOUR_SERVER_IP

# ── JWT (generate: openssl rand -base64 48) ───────────────────────────────────
JWT_ACCESS_SECRET=your-jwt-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_MONTHLY_PRICE_ID=price_monthly
STRIPE_YEARLY_PRICE_ID=price_yearly
STRIPE_TWO_YEAR_PRICE_ID=price_2year

# ── Square ────────────────────────────────────────────────────────────────────
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=placeholder
SQUARE_LOCATION_ID=placeholder
SQUARE_WEBHOOK_SIGNATURE_KEY=placeholder

# ── Paddle ────────────────────────────────────────────────────────────────────
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=placeholder
PADDLE_WEBHOOK_SECRET=placeholder
PADDLE_MONTHLY_PRICE_ID=placeholder
PADDLE_YEARLY_PRICE_ID=placeholder
PADDLE_TWO_YEAR_PRICE_ID=placeholder

# ── Coinbase Commerce ─────────────────────────────────────────────────────────
COINBASE_COMMERCE_API_KEY=placeholder
COINBASE_WEBHOOK_SECRET=placeholder

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.example.com

# ── WireGuard ─────────────────────────────────────────────────────────────────
WIREGUARD_ENABLED=false
WIREGUARD_SERVER_PRIVATE_KEY=your-wg-private-key
WIREGUARD_SUBNET=10.8.0.0/24
WIREGUARD_PORT=51820

# ── Support ───────────────────────────────────────────────────────────────────
WHATSAPP_SUPPORT_NUMBER=+905368895622

# ── Misc ──────────────────────────────────────────────────────────────────────
ENABLE_SELF_HEALING=false
AUTO_REFRESH_INTERVAL_MS=30000
MAX_RECONNECT_ATTEMPTS=5
DOWNLOADS_DIR=/app/downloads
BCRYPT_ROUNDS=12
TRIAL_DURATION_DAYS=3
DEMO_DURATION_MINUTES=60
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
