{
  "name": "geminivpn-backend",
  "version": "3.0.0",
  "description": "GeminiVPN Platform Backend — Stripe · Square · Paddle · Coinbase",
  "main": "dist/server.js",
  "scripts": {
    "dev":               "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":             "tsc --skipLibCheck",
    "start":             "node dist/server.js",
    "db:generate":       "prisma generate",
    "db:migrate":        "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed":           "ts-node prisma/seed.ts",
    "db:studio":         "prisma studio",
    "test":              "jest --runInBand --forceExit",
    "lint":              "eslint src --ext .ts --ignore-pattern 'src/__tests__'",
    "lint:fix":          "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@prisma/client":     "5.22.0",
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator":  "^7.0.1",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "node-cron":          "^3.0.3",
    "node-fetch":         "^2.7.0",
    "qrcode":             "^1.5.3",
    "stripe":             "^14.9.0",
    "uuid":               "^9.0.1",
    "winston":            "^3.11.0",
    "ws":                 "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs":             "^2.4.6",
    "@types/cors":                 "^2.8.17",
    "@types/express":              "^4.17.21",
    "@types/jest":                 "^29.5.12",
    "@types/jsonwebtoken":         "^9.0.5",
    "@types/node":                 "^20.10.5",
    "@types/node-cron":            "^3.0.11",
    "@types/node-fetch":           "^2.6.11",
    "@types/qrcode":               "^1.5.5",
    "@types/uuid":                 "^9.0.7",
    "@types/ws":                   "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser":        "^6.15.0",
    "eslint":                      "^8.56.0",
    "jest":                        "^29.7.0",
    "prisma":                      "5.22.0",
    "ts-jest":                     "^29.1.1",
    "ts-node":                     "^10.9.2",
    "ts-node-dev":                 "^2.0.0",
    "typescript":                  "^5.3.3"
  },
  "engines": { "node": ">=18.0.0" },
  "keywords": ["vpn", "wireguard", "stripe", "square", "paddle", "coinbase", "typescript"],
  "author": "GeminiVPN Team",
  "license": "MIT"
}
