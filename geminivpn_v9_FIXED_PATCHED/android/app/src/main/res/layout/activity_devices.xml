<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/gemini_bg">

  <!-- Toolbar -->
  <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:paddingStart="8dp" android:paddingEnd="16dp"
      android:background="@color/gemini_bg2">
    <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="←"
        android:textColor="@color/gemini_cyan" android:textSize="20sp"
        style="?attr/borderlessButtonStyle"/>
    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/title_devices"
        android:textSize="18sp" android:textStyle="bold"
        android:textColor="@color/text_primary"/>
    <TextView android:id="@+id/tvDeviceCount" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="12sp"
        android:textColor="@color/text_secondary" android:layout_marginEnd="8dp"/>
    <Button android:id="@+id/btnAddDevice" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="@string/btn_add_device"
        android:backgroundTint="@color/gemini_cyan" android:textColor="@color/black"
        android:textSize="12sp"/>
  </LinearLayout>

  <!-- Devices RecyclerView -->
  <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/rvDevices"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:clipToPadding="false"
      android:padding="8dp"/>

</LinearLayout>
