<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/gemini_bg">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="24dp">
    <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="← Back"
        android:textColor="@color/gemini_cyan" style="?attr/borderlessButtonStyle"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Choose Your Plan" android:textSize="24sp" android:textStyle="bold"
        android:textColor="@color/text_primary" android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btnMonthly" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="@string/label_plan_monthly"
        android:backgroundTint="@color/gemini_bg2" android:textColor="@color/text_primary"
        android:layout_marginBottom="12dp" android:textStyle="bold"/>
    <Button android:id="@+id/btnYearly" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="@string/label_plan_yearly"
        android:backgroundTint="@color/gemini_cyan" android:textColor="@color/black"
        android:layout_marginBottom="12dp" android:textStyle="bold"/>
    <Button android:id="@+id/btnTwoYear" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="@string/label_plan_two_year"
        android:backgroundTint="@color/gemini_bg2" android:textColor="@color/text_primary"
        android:layout_marginBottom="24dp" android:textStyle="bold"/>
    <ProgressBar android:id="@+id/progressBar" android:layout_width="32dp"
        android:layout_height="32dp" android:layout_gravity="center"
        android:indeterminateTint="@color/gemini_cyan" android:visibility="gone"/>
  </LinearLayout>
</ScrollView>
