[Unit]
Description=GeminiVPN Platform (Docker Compose)
Documentation=https://geminivpn.access.ly
After=network-online.target docker.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/geminivpn/docker
EnvironmentFile=/opt/geminivpn/.env

ExecStartPre=/usr/local/bin/docker-compose pull --quiet 2>/dev/null || true
ExecStart=/usr/local/bin/docker-compose up -d --remove-orphans
ExecStop=/usr/local/bin/docker-compose down --timeout 30
ExecReload=/usr/local/bin/docker-compose restart

TimeoutStartSec=300
TimeoutStopSec=60

Restart=on-failure
RestartSec=15s

# Log to journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=geminivpn

[Install]
WantedBy=multi-user.target
