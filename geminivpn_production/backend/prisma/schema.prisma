// GeminiVPN Database Schema
// This schema defines all entities for the VPN platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model with subscription tracking
model User {
  id                String          @id @default(uuid())
  email             String          @unique
  password          String          // Hashed with bcrypt
  name              String?
  
  // Subscription fields
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt       DateTime?       // 3-day trial end date
  subscriptionEndsAt DateTime?      // Paid subscription end date
  
  // Account metadata
  isActive          Boolean         @default(true)
  isTestUser        Boolean         @default(false)
  emailVerified     Boolean         @default(false)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lastLoginAt       DateTime?
  
  // Relations
  vpnClients        VPNClient[]
  payments          Payment[]
  sessions          Session[]
  connectionLogs    ConnectionLog[]
  
  @@index([email])
  @@index([subscriptionStatus])
  @@index([isActive])
  @@map("users")
}

// VPN Client configuration per user
model VPNClient {
  id                String          @id @default(uuid())
  userId            String
  
  // WireGuard configuration
  clientName        String          // Device name (e.g., "iPhone 15", "MacBook Pro")
  publicKey         String          @unique // WireGuard public key
  privateKey        String          // Encrypted private key
  presharedKey      String?         // Optional PSK for extra security
  
  // IP allocation
  assignedIp        String          @unique // Internal VPN IP (10.x.x.x)
  
  // Server assignment
  serverId          String
  
  // Connection status
  isConnected       Boolean         @default(false)
  lastConnectedAt   DateTime?
  dataTransferred   BigInt          @default(0) // Bytes transferred
  
  // QR Code for mobile setup
  qrCodeData        String?         // Base64 QR code image
  configFile        String?         // WireGuard config file content
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  server            VPNServer       @relation(fields: [serverId], references: [id])
  
  @@index([userId])
  @@index([serverId])
  @@index([isConnected])
  @@map("vpn_clients")
}

// VPN Server nodes worldwide
model VPNServer {
  id                String          @id @default(uuid())
  
  // Location info
  name              String          // Display name (e.g., "New York USA")
  country           String          // Country code (US, UK, etc.)
  city              String
  region            String?         // State/Province
  
  // Network configuration
  hostname          String          // Server hostname/IP
  port              Int             @default(51820)
  publicKey         String          // Server's WireGuard public key
  
  // Server status
  isActive          Boolean         @default(true)
  isMaintenance     Boolean         @default(false)
  loadPercentage    Int             @default(0) // 0-100 server load
  
  // Performance metrics
  latencyMs         Int?            // Average latency
  maxClients        Int             @default(1000)
  currentClients    Int             @default(0)
  
  // IP pool configuration
  subnet            String          // e.g., "10.8.0.0/24"
  dnsServers        String[]        // DNS servers for clients
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lastHealthCheck   DateTime?
  
  // Relations
  clients           VPNClient[]
  
  @@index([country])
  @@index([isActive])
  @@index([loadPercentage])
  @@map("vpn_servers")
}

// Payment records (Stripe integration)
model Payment {
  id                String          @id @default(uuid())
  userId            String
  
  // Stripe fields
  stripePaymentId   String?         @unique
  stripeCustomerId  String?
  stripeSubscriptionId String?      @unique
  
  // Payment details
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("USD")
  status            PaymentStatus   @default(PENDING)
  paymentMethod     PaymentMethod   // CARD, PAYPAL, etc.
  
  // Plan info
  planType          PlanType        // MONTHLY, YEARLY, etc.
  planName          String          // Display name
  
  // Metadata
  description       String?
  receiptUrl        String?         // Stripe receipt URL
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  paidAt            DateTime?
  
  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([stripePaymentId])
  @@index([status])
  @@map("payments")
}

// User sessions for authentication
model Session {
  id                String          @id @default(uuid())
  userId            String
  
  // Session tokens
  refreshToken      String          @unique
  accessToken       String?         // Optional: store latest access token
  
  // Session metadata
  ipAddress         String?
  userAgent         String?
  deviceInfo        String?         // Parsed device info
  
  // Session status
  isValid           Boolean         @default(true)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  expiresAt         DateTime        // Refresh token expiry
  lastUsedAt        DateTime        @default(now())
  revokedAt         DateTime?
  
  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([refreshToken])
  @@index([isValid])
  @@map("sessions")
}

// Connection logs for analytics and debugging
model ConnectionLog {
  id                String          @id @default(uuid())
  userId            String
  
  // Connection details
  eventType         ConnectionEvent // CONNECT, DISCONNECT, ERROR
  serverId          String?
  clientId          String?
  
  // Network info
  clientIp          String?         // User's real IP (hashed for privacy)
  assignedIp        String?         // VPN-assigned IP
  
  // Error info
  errorCode         String?
  errorMessage      String?
  
  // Performance
  duration          Int?            // Connection duration in seconds
  dataTransferred   BigInt?         // Bytes during session
  
  // Timestamps
  createdAt         DateTime        @default(now())
  
  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("connection_logs")
}

// System configuration
model SystemConfig {
  id                String          @id @default(uuid())
  key               String          @unique
  value             String
  description       String?
  updatedAt         DateTime        @updatedAt
  
  @@map("system_config")
}

// Enums
enum SubscriptionStatus {
  TRIAL           // 3-day free trial
  ACTIVE          // Paid subscription active
  EXPIRED         // Subscription expired
  CANCELLED       // User cancelled
  SUSPENDED       // Payment failed or violation
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CARD            // Credit/Debit card via Stripe
  PAYPAL          // PayPal via Stripe
  APPLE_PAY       // Apple Pay
  GOOGLE_PAY      // Google Pay
}

enum PlanType {
  MONTHLY
  YEARLY
  TWO_YEAR
  LIFETIME
}

enum ConnectionEvent {
  CONNECT
  DISCONNECT
  ERROR
  RECONNECT
  HEALING_TRIGGERED
}
