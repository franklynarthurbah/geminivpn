<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Theme.GeminiVPN" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gemini_cyan</item>
        <item name="colorPrimaryVariant">@color/gemini_cyan_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/gemini_purple</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/gemini_bg2</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/gemini_bg</item>
        <item name="colorError">@color/status_error</item>
        <item name="android:statusBarColor">@color/gemini_bg</item>
        <item name="android:navigationBarColor">@color/gemini_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.GeminiVPN.Splash" parent="Theme.GeminiVPN">
        <item name="android:windowBackground">@color/gemini_bg</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.GeminiVPN.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gemini_cyan</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.GeminiVPN.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/status_error</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- TextInput style -->
    <style name="Widget.GeminiVPN.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gemini_border</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/gemini_bg2</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

</resources>
