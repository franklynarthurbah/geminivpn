# =============================================================================
# GeminiVPN Platform — Production Environment
# Domain: geminivpn.zapto.org  IP: 167.71.197.103
# Copy to .env, fill in real values, NEVER commit .env to git
# =============================================================================

DB_USER=geminivpn
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=geminivpn
DATABASE_URL=postgresql://geminivpn:CHANGE_ME_strong_password_here@postgres:5432/geminivpn?schema=public

REDIS_PASSWORD=CHANGE_ME_redis_password_here

NODE_ENV=production
BACKEND_PORT=5000
FRONTEND_URL=https://geminivpn.zapto.org

# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_MONTHLY_PRICE_ID=price_CHANGE_ME
STRIPE_YEARLY_PRICE_ID=price_CHANGE_ME
STRIPE_TWO_YEAR_PRICE_ID=price_CHANGE_ME

# Generate: wg genkey
WIREGUARD_ENABLED=true
WIREGUARD_INTERFACE=wg0
WIREGUARD_SERVER_PRIVATE_KEY=CHANGE_ME_wg_genkey_output

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@geminivpn.zapto.org

WHATSAPP_SUPPORT_NUMBER=+905368895622
SUPPORT_EMAIL=support@geminivpn.zapto.org

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_TRIAL=true
TRIAL_DURATION_DAYS=3
ENABLE_SELF_HEALING=true
AUTO_REFRESH_INTERVAL_MS=30000
MAX_RECONNECT_ATTEMPTS=5
LOG_LEVEL=info

# App Downloads
IOS_APP_STORE_URL=https://apps.apple.com/app/geminivpn
DOWNLOADS_DIR=/app/downloads

# Self-healing
ENABLE_SELF_HEALING=false
MAX_RECONNECT_ATTEMPTS=5
AUTO_REFRESH_INTERVAL_MS=30000
