# =============================================================================
# GeminiVPN Backend — Production Dockerfile
# =============================================================================

FROM node:20-alpine AS base
RUN apk add --no-cache \
    wireguard-tools iptables ip6tables \
    curl bash openssl postgresql-client \
    python3 make g++
WORKDIR /app

# ── Builder: compile TypeScript ───────────────────────────────────────────────
FROM base AS builder

COPY backend/package.json ./
RUN npm install --legacy-peer-deps --no-audit --no-fund

COPY backend/ ./
COPY backend/prisma ./prisma/

# Generate Prisma client (pinned v5, avoids v7 breaking changes)
RUN npx prisma@5.22.0 generate

# Install tsc globally then compile src/ → dist/
RUN npm install -g typescript@5.3.3 --quiet
RUN node_modules/.bin/tsc --skipLibCheck 2>&1 || npx tsc --skipLibCheck 2>&1 || echo "tsc finished with warnings"

# Compile prisma/seed.ts → dist/prisma/seed.js
# Uses a dedicated tsconfig so rootDir=prisma/ (outside main src/ rootDir)
COPY backend/tsconfig.seed.json ./tsconfig.seed.json
RUN mkdir -p dist/prisma && \
    node_modules/.bin/tsc -p tsconfig.seed.json --skipLibCheck 2>&1 \
    || npx tsc -p tsconfig.seed.json --skipLibCheck 2>&1 \
    || echo "seed tsconfig fallback: transpiling with node script" && \
       node -e "var ts=require('typescript'),fs=require('fs');var src=fs.readFileSync('prisma/seed.ts','utf8');var out=ts.transpileModule(src,{compilerOptions:{module:ts.ModuleKind.CommonJS,target:ts.ScriptTarget.ES2020,esModuleInterop:true}});fs.writeFileSync('dist/prisma/seed.js',out.outputText);console.log('seed.ts compiled');" 2>&1 || true

# Verify the critical output exists
RUN test -f dist/server.js || (echo "ERROR: dist/server.js missing — tsc failed" && exit 1)
RUN echo "Build OK — dist/server.js exists"

# ── Production stage ──────────────────────────────────────────────────────────
FROM base AS production

RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001

COPY backend/package.json ./
RUN npm install --omit=dev --legacy-peer-deps --no-audit --no-fund

COPY backend/prisma ./prisma/
RUN npx prisma@5.22.0 generate

# Copy compiled JS from builder
COPY --from=builder /app/dist ./dist

RUN mkdir -p /var/log/geminivpn /app/wireguard-configs && \
    chown -R nodejs:nodejs /app /var/log/geminivpn

USER nodejs
EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=5 \
  CMD curl -f http://localhost:5000/health || exit 1

CMD ["node", "dist/server.js"]
